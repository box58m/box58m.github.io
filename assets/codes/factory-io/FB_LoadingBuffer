FUNCTION_BLOCK FB_LoadingBuffer
VAR_INPUT
    Enable           : BOOL;
    Reset            : BOOL;

    PartDetected     : BOOL;
    PalletInPosition : BOOL;
    LoadPermission   : BOOL;

    TargetCount      : INT := 3;
	SortTime         : TIME := T#2S;
    LoadTime         : TIME := T#8S;
END_VAR


VAR_OUTPUT
	PivotArmCommand : BOOL;
	ArmBeltRun   : BOOL;
    BufferBeltRun  : BOOL;
    BufferReady    : BOOL;
    RequestPallet  : BOOL;
    LoadingBusy    : BOOL;
    BatchComplete  : BOOL;
    BufferedCount  : INT;
    State          : INT;
END_VAR


VAR
    PartEdge  : R_TRIG;
	SortTimer : TON;
    LoadTimer : TON;
END_VAR







PartEdge(CLK := PartDetected);

BatchComplete := FALSE;
BufferReady := BufferedCount >= TargetCount;

CASE State OF

    0: // Wait for product
        PivotArmCommand := FALSE;
		ArmBeltRun := FALSE;
        BufferBeltRun := FALSE;

        LoadingBusy := FALSE;
        RequestPallet := FALSE;

        SortTimer(IN := FALSE);
        LoadTimer(IN := FALSE);

        IF Enable AND PartEdge.Q AND BufferedCount < TargetCount THEN
            State := 1;
        END_IF;


    1: // Sort product into this buffer
        PivotArmCommand := TRUE;
        BufferBeltRun := FALSE;
		ArmBeltRun := TRUE;

        SortTimer(
            IN := TRUE,
            PT := SortTime
        );

        IF SortTimer.Q THEN
            SortTimer(IN := FALSE);

            PivotArmCommand := FALSE;
            BufferBeltRun := FALSE;

            BufferedCount := BufferedCount + 1;

            IF BufferedCount >= TargetCount THEN
                State := 2;
            ELSE
                State := 0;
            END_IF;
        END_IF;


    2: // Buffer full; request pallet
        PivotArmCommand := FALSE;
		ArmBeltRun := FALSE;
        BufferBeltRun := FALSE;

        LoadingBusy := FALSE;
        RequestPallet := TRUE;

        IF LoadPermission AND PalletInPosition THEN
            State := 3;
        END_IF;


    3: // Load products onto pallet
        PivotArmCommand := FALSE;
        BufferBeltRun := TRUE;
		ArmBeltRun := FALSE;
        LoadingBusy := TRUE;
        RequestPallet := FALSE;

        LoadTimer(
            IN := TRUE,
            PT := LoadTime
        );

        IF LoadTimer.Q THEN
            LoadTimer(IN := FALSE);

            BufferBeltRun := FALSE;
            LoadingBusy := FALSE;

            BufferedCount := 0;
            BatchComplete := TRUE;
            State := 0;
        END_IF;

END_CASE;

IF Reset THEN
    State := 0;
    BufferedCount := 0;

    PivotArmCommand := FALSE;
	ArmBeltRun := FALSE;
    BufferBeltRun := FALSE;

    BufferReady := FALSE;
    RequestPallet := FALSE;
    LoadingBusy := FALSE;
    BatchComplete := FALSE;

    SortTimer(IN := FALSE);
    LoadTimer(IN := FALSE);
END_IF;
