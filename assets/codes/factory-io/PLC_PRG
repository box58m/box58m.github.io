    Crane0Busy : BOOL;
    Crane1Busy : BOOL;
    Crane2Busy : BOOL;

    Crane0CycleDone : BOOL;
    Crane1CycleDone : BOOL;
    Crane2CycleDone : BOOL;

    Crane0StorageFull : BOOL;
    Crane1StorageFull : BOOL;
