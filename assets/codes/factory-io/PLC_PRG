	AssemblyDone : BOOL;
	
	AssemblyCell : FB_AssemblyCell;
	
	
	BlueInspection : FB_AssemblyInspection;
	GreenInspection : FB_AssemblyInspection;
	MetalInspection : FB_AssemblyInspection;
	
	BlueLoad : FB_LoadingBuffer;
	GreenLoad : FB_LoadingBuffer;
	MetalLoad : FB_LoadingBuffer;
	
	BlueLoadComplete : BOOL;
	GreenLoadComplete : BOOL;
	MetalLoadComplete : BOOL;
	
	
	BlueLoadGrant  : BOOL;
    GreenLoadGrant : BOOL;
    MetalLoadGrant : BOOL;
	
	
	LoadingDispatcher : FB_LoadingDispatcher;
	LoadingDispatcherBusy  : BOOL;
    LoadingDestination     : INT;
    LoadingDispatcherState : INT;
    DispatchAreaClear      : BOOL;
	BluePalletRequest  : BOOL;
    GreenPalletRequest : BOOL;
    MetalPalletRequest : BOOL;
	
	BlueLoadingDone : BOOL;
	GreenLoadingDone : BOOL;
	MetalLoadingDone : BOOL;
	

    PalletTurntable : FB_PalletTurntable;

